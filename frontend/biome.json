{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["src/features/news/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/news 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features 直接参照も禁止 (features/watchlist のみ Public API '@/features/watchlist' 経由で compose 可)。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/watchlist/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/watchlist 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/sources/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/sources 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/auth/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/auth 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/digest/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/digest",
                      "@/features/digest/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**"
                    ],
                    "message": "features/digest 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}

{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!src/types/*.gen.ts",
      "!src/types/client/**",
      "!src/types/core/**"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@/types/generated": "Use '@/types/types.gen' for hey-api generated types, or '@/types' for narrowed re-exports. The legacy openapi-typescript generated.ts has been removed in PR-H4b."
            }
          }
        }
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "vitest.config.mts",
        "vitest.setup.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["src/features/news/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/news 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features 直接参照も禁止 (features/watchlist のみ Public API '@/features/watchlist' 経由で compose 可)。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/watchlist/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/watchlist 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/sources/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/sources 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/auth/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/auth",
                      "@/features/auth/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/digest",
                      "@/features/digest/**"
                    ],
                    "message": "features/auth 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/digest/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/digest",
                      "@/features/digest/**",
                      "@/features/news",
                      "@/features/news/**",
                      "@/features/watchlist",
                      "@/features/watchlist/**",
                      "@/features/sources",
                      "@/features/sources/**",
                      "@/features/auth",
                      "@/features/auth/**"
                    ],
                    "message": "features/digest 内では自 feature を deep path / Public API 経由で import せず相対 import を使うこと。他 features は Public API '@/features/<name>' のみ。"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "src/app/**",
        "src/components/**",
        "src/lib/**",
        "src/proxy.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/features/*/**"],
                    "message": "features 配下は Public API '@/features/<name>' 経由のみ。内部実装への deep import は禁止。"
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}

    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "next": "^16.2.11",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "redis": "^6.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remend": "^1.3.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",

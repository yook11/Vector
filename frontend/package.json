{
  "name": "vector-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "generate-types": "openapi-ts",
    "generate-types:file": "OPENAPI_INPUT=./openapi.json openapi-ts"
  },
  "dependencies": {
    "@hey-api/client-next": "0.5.1",

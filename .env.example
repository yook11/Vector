# ===========================
# Deployment Environment (red-team S-EXFIL-1 / C3 防御)
# ===========================
# production では FastAPI の自動 docs (/docs, /redoc, /openapi.json) を
# 無効化する。値は "development" / "production" の 2 択 (Literal で固定)。
# 本番 deploy では fly.toml [env] で "production" を渡すため、.env では
# 設定不要 (未設定なら default の "development" で動作)。
# ENV=development

# ===========================
# Database
# ===========================
# vector: table owner / migration runner (alembic + tests + admin scripts)
POSTGRES_USER=vector
POSTGRES_PASSWORD=<set-strong-password-or-openssl-rand-hex-32>
POSTGRES_DB=vector
# red-team AUTH-N4: application 接続専用ロールのパスワード
# vector_auth:    frontend の Better Auth 経由で auth.* に DML
# vector_app:     backend core (api / worker-analysis / worker-insights / scheduler)
#                 が public.* に DML
# vector_collect: collect worker (acquisition + completion) が触る public の
#                 4 table (articles / incomplete_articles / news_sources /
#                 pipeline_events) だけに絞った最小権限ロール
# init script (infra/db/init/01_create_app_users.sh) で role を作るときに使う
POSTGRES_AUTH_PASSWORD=<set-strong-password-or-openssl-rand-hex-32>
POSTGRES_APP_PASSWORD=<set-strong-password-or-openssl-rand-hex-32>
POSTGRES_COLLECT_PASSWORD=<set-strong-password-or-openssl-rand-hex-32>

# --- Production (Neon) ---
# dev (docker 同一 network) は上記 POSTGRES_* から compose が接続文字列を組むため
# 平文で良い。本番は Neon (managed Postgres, public internet 越し) のため TLS 必須。
# 下記 URL は **本番 deploy では Fly secrets で注入**し、.env には置かない (参考)。
#
# backend (asyncpg) — DATABASE_URL=vector_app / MIGRATION_DATABASE_URL=vector。
# どちらも `?sslmode=require` を付ける (ENV=production では config.py が sslmode
# 未指定 / 平文を起動時に拒否する)。SSL は backend/app/db_ssl.py が sslmode から
# verify-full の SSLContext に変換する (certifi CA + ホスト名検証)。
# DATABASE_URL=postgresql+asyncpg://vector_app:<pw>@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# MIGRATION_DATABASE_URL=postgresql+asyncpg://vector:<pw>@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# AUTH_RETENTION_DATABASE_URL=postgresql+asyncpg://vector_auth:<pw>@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
#
# frontend (node-pg) 専用 — backend は読まない。consume は
# frontend/src/lib/auth/{auth,auth.cli}.ts。同じ `?sslmode=require` を
# frontend/src/lib/auth/pool-ssl.ts が `{rejectUnauthorized:true}` (verify-full
# 相当) に変換する。`search_path=auth` は node-pg のみ有効 — backend の
# `postgresql+asyncpg://` URL に付けると asyncpg.connect が TypeError になるため
# 付けない (backend は schema を明示参照する)。
# AUTH_DATABASE_URL=postgresql://vector_auth:<pw>@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&search_path=auth
#
# 規約: 全層 `?sslmode=require` の 1 本に統一。`require` は両 helper が verify-full
# に格上げする (public internet の MITM 防御)。平文にしたいのは `sslmode=disable`
# のときだけ。

# ===========================
# AI API
# ===========================
# Adapter の選択は backend/app/brokers.py で hardcode する設計（Pure DI）。
# ここではキーのみ。実装側で必要なキーが未設定の場合 worker 起動時に
# ConfigurationError で落ちる。
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===========================
# News Fetcher
# ===========================
FETCH_INTERVAL_HOURS=12
MAX_ARTICLES_PER_FETCH=50
MAX_ANALYSIS_PER_RUN=10

# ===========================
# Content Extraction
# ===========================
CONTENT_MAX_LENGTH=8000

# ===========================
# Auth (Better Auth + BFF Proxy)
# ===========================
# 強い乱数を生成して設定する: `openssl rand -hex 32`
# このまま `.env` にコピーすると backend 起動時に長さ不足で拒否される。
BETTER_AUTH_SECRET=<openssl-rand-hex-32>
BETTER_AUTH_URL=http://localhost:3000
# 内部 trust 境界の共有秘密 (red-team C1 防御で 2 つに分離):
# - BFF_JWT_SIGNING_SECRET:  BFF→backend の HS256 JWT 署名/検証鍵
# - REVALIDATE_BEARER_SECRET: backend→frontend revalidate の Bearer
# それぞれ別の乱数を設定すること (同一値は片方漏洩で両境界が陥落するため拒否)。
# どちらも frontend (署名/送信) と backend (検証) の双方で同値を設定する。
BFF_JWT_SIGNING_SECRET=<openssl-rand-hex-32>
REVALIDATE_BEARER_SECRET=<openssl-rand-hex-32-different>

# ===========================
# Task Queue (Redis) — backend / worker / scheduler 共通 (db0)
# ===========================
REDIS_URL=redis://localhost:6379/0

# ===========================
# Frontend Rate Limit Redis (red-team C9 対策)
# ===========================
# frontend proxy.ts の rate-limit (rl:ip:* / rl:sess:* / rl:rsc:* / rl:uwrite:global) 専用 instance。
# 本体 REDIS_URL (taskiq broker 同居) と物理分離して OOM 道連れを防ぐ。
# Better Auth のログイン limiter は DB-backed (storage:"database", ADR-007) のため
# ここには載らない (この instance は proxy rate limiter 専用)。
# 未設定時は REDIS_URL にフォールバックする (managed Redis 単一構成への退避経路)。
# docker compose 経由なら redis-rl:6379/0 が DNS 解決される。下記は host 直起動時の参考値。
REDIS_URL_RL=redis://localhost:6380/0

# ===========================
# Rate Limit (proxy 層 / ADR-009 multi-tier)
# ===========================
# proxy.ts の application-level rate limit。request class × identity で tier 分割した
# sliding window log。未設定時は下記デフォルトで動作する (env override は任意)。
#   - rl:rsc:<ip>       … _rsc prefetch GET の寛容 ceiling (別財布)
#   - rl:sess:<hash>    … 認証済 session sub-bucket
#   - rl:ip:<ip>        … per-IP ceiling (forge-bypass backstop)
#   - rl:uwrite:global  … IP 未解決 & anon の mutation のみ縛る共有 bucket
# RATE_LIMIT_RSC_PER_MIN=600
# RATE_LIMIT_SESSION_PER_MIN=60
# RATE_LIMIT_IP_PER_MIN=300
# RATE_LIMIT_UNKNOWN_WRITE_PER_MIN=30
#
# [運用移行メモ] 旧 RATE_LIMIT_PER_MIN (単一 per-IP 60) は deprecate (コードは読まない)。
# Fly secrets 等に旧 env を設定済みの環境は上記 4 env へ移行すること
# (未設定なら新デフォルトで動作する)。

# ===========================
# Observability (Logfire)
# ===========================
# production のみ Fly secret (LOGFIRE_TOKEN) で投入する。dev / CI / test は
# 未設定のままで OK: send_to_logfire="if-token-present" により logfire は
# 完全 no-op (外部送信ゼロ) となる。token を入れた瞬間に Logfire dashboard へ
# trace/log が流れ始める設計 (Phase 1 では structlog 経由のログのみ)。
# LOGFIRE_TOKEN=

# ===========================
# Pipeline Backfill (kill switches)
# ===========================
# 段階的有効化: Step 1 で curations、Step 2 で assessments、
# Step 3 で embeddings を順に true に切り替える。
BACKFILL_CURATIONS_ENABLED=true
BACKFILL_ASSESSMENTS_ENABLED=true
BACKFILL_EMBEDDINGS_ENABLED=true

# ===========================
# App URLs
# ===========================
FRONTEND_URL=http://localhost:3000
# backend → frontend container を直接呼び出す経路用 (revalidate 通知など)。
# 許可宛先は config.py の validator で localhost / 127.0.0.1 / frontend / *.flycast に
# 限定 (notifier の REVALIDATE_BEARER_SECRET 持ち出し口を構造遮断)。
# 本番 (ENV=production) は *.flycast のみ許可: `http://your-vector-frontend-app.flycast:3000`。
# compose / CI / dev では `http://frontend:3000`。
INTERNAL_FRONTEND_BASE_URL=http://frontend:3000

# ===========================
# Frontend (Next.js BFF)
# ===========================
# frontend は client から backend を直接叩かない (BFF パターン)。
# Server Components / Server Actions / Route Handlers のみが backend に到達し、
# 本値は server-only import (frontend/src/lib/api/internal-config.ts) で評価
# されるため client bundle には出ない。
# 本番 (Fly) は frontend/fly.toml [env] で
# `http://your-vector-core-app.flycast:8000/api/v1` (flycast 内部通信) を設定。
# 起動時 narrowing: NODE_ENV=production では host が *.flycast でなければ fail-closed。
INTERNAL_API_URL=http://backend:8000/api/v1

# ===========================
# Docker Compose Port Mapping
# ===========================
# db は internal network 限定 (red-team AUTH-C1 対応) のため host port は宣言しない。
# host から psql を使うときは `docker compose exec db psql -U vector vector` で
# container 内 psql を使用する。
REDIS_PORT=6379

# ===========================
# Test minimum (pytest collection に必要な 5 つ)
# ===========================
# backend/app/config.py の ``Settings`` は required field に default を持たないため
# (red-team S-AUTH-4 + S-SECRET-1 / 本番 fail-fast 維持)、.env も env も無い
# 状態で ``from app.config import settings`` は ValidationError で爆発する。
# pytest は backend/tests/conftest.py がこの import を踏むため collection 段階で
# 全テストを諦める。
#
# ローカル / CI は本セクションの 5 つ (DATABASE_URL / BFF_JWT_SIGNING_SECRET /
# REVALIDATE_BEARER_SECRET / FRONTEND_URL / INTERNAL_FRONTEND_BASE_URL) が
# 埋まっていれば collection が通る。
# 上記 Database / Auth セクションで実値を設定済みなら本セクションは不要。
# .env を持たない sandbox / agent 環境は backend/tests/conftest.py 冒頭の
# ``os.environ.setdefault`` で構造的に救済される (本セクションはあくまで env contract
# の明文化であり、conftest の dummy がこの env contract を満たす)。

# ===========================
# E2E Test Seed (CI only — production では設定しない / red-team C2 防御)
# ===========================
# backend/scripts/seed_e2e_users.py が読む env 変数。i4_seed_e2e_users migration
# を削除し E2E seed を CI 専用 script に分離した PR4 で導入。**本番 .env には
# 設定しないこと**。script 自体も ENV=production で sys.exit(2) で fail-fast
# するが、env 自体を本番に置かないのが第一の防護壁。未設定なら下記 default 値。
# E2E_SEED_USER_EMAIL=e2e@example.com
# E2E_SEED_USER_PASSWORD=Password123!
# E2E_SEED_ADMIN_EMAIL=e2e-admin@example.com
# E2E_SEED_ADMIN_PASSWORD=Password123!

# ===========================
# Database
# ===========================
POSTGRES_USER=vector
POSTGRES_PASSWORD=vector
POSTGRES_DB=vector
DATABASE_URL=postgresql+asyncpg://vector:vector@db:5432/vector

# ===========================
# AI API
# ===========================
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===========================
# News Fetcher
# ===========================
FETCH_INTERVAL_HOURS=12
MAX_ARTICLES_PER_FETCH=50
MAX_ANALYSIS_PER_RUN=10

# ===========================
# Content Extraction
# ===========================
CONTENT_MAX_LENGTH=8000

# ===========================
# Embedding (Rate Limit)
# ===========================
EMBED_BATCH_SIZE=10
EMBED_BATCH_INTERVAL=8.0
EMBED_RATE_LIMIT_DELAY=60.0
EMBED_MAX_CONSECUTIVE_FAILURES=3

# ===========================
# Auth (Better Auth + BFF Proxy)
# ===========================
BETTER_AUTH_SECRET=change-me-in-production-use-a-strong-random-secret
BETTER_AUTH_URL=http://localhost:3000
INTERNAL_API_SECRET=change-me-in-production
AUTH_DATABASE_URL=postgresql://vector:vector@db:5432/vector?search_path=auth

# ===========================
# Task Queue (Redis)
# ===========================
REDIS_URL=redis://localhost:6379/0

# ===========================
# App URLs
# ===========================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ===========================
# Frontend
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ===========================
# Frontend (Next.js BFF)
# ===========================
INTERNAL_API_URL=http://backend:8000/api/v1

# ===========================
# Docker Compose Port Mapping
# ===========================
DB_PORT=5433
REDIS_PORT=6379

# ===========================
# Database
# ===========================
POSTGRES_USER=vector
POSTGRES_PASSWORD=vector
POSTGRES_DB=vector
DATABASE_URL=postgresql+asyncpg://vector:vector@db:5432/vector

# ===========================
# AI API
# ===========================
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===========================
# News Fetcher
# ===========================
FETCH_INTERVAL_HOURS=12
MAX_ARTICLES_PER_FETCH=50
MAX_ANALYSIS_PER_RUN=10

# ===========================
# Content Extraction
# ===========================
CONTENT_MAX_LENGTH=8000

# ===========================
# Embedding (Rate Limit)
# ===========================
EMBED_BATCH_SIZE=10
EMBED_BATCH_INTERVAL=8.0
EMBED_RATE_LIMIT_DELAY=60.0
EMBED_MAX_CONSECUTIVE_FAILURES=3

# ===========================
# Auth / JWT
# ===========================
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
JWT_REFRESH_GRACE_PERIOD_SECONDS=10

# ===========================
# Task Queue (Redis)
# ===========================
REDIS_URL=redis://localhost:6379/0

# ===========================
# App URLs
# ===========================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ===========================
# Frontend
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ===========================
# NextAuth.js
# ===========================
NEXTAUTH_SECRET=change-me-in-production-use-a-strong-random-secret
NEXTAUTH_URL=http://localhost:3000

# ===========================
# Docker Compose Port Mapping
# ===========================
DB_PORT=5433
REDIS_PORT=6379

# ===========================
# Database
# ===========================
POSTGRES_USER=vector
POSTGRES_PASSWORD=vector
POSTGRES_DB=vector
DATABASE_URL=postgresql+asyncpg://vector:vector@db:5432/vector

# ===========================
# AI API
# ===========================
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ===========================
# News Fetcher
# ===========================
FETCH_INTERVAL_HOURS=12
MAX_ARTICLES_PER_FETCH=50
MAX_ANALYSIS_PER_RUN=10

# ===========================
# Content Extraction
# ===========================
CONTENT_MAX_LENGTH=8000

# ===========================
# Embedding (TEI ローカル推論)
# ===========================
EMBEDDING_BASE_URL=http://embedding:80

# ===========================
# Auth (Better Auth + BFF Proxy)
# ===========================
# 強い乱数を生成して設定する: `openssl rand -hex 32`
# このまま `.env` にコピーすると backend 起動時に長さ不足で拒否される。
BETTER_AUTH_SECRET=<openssl-rand-hex-32>
BETTER_AUTH_URL=http://localhost:3000
INTERNAL_API_SECRET=<openssl-rand-hex-32>
AUTH_DATABASE_URL=postgresql://vector:vector@db:5432/vector?search_path=auth

# ===========================
# Task Queue (Redis)
# ===========================
REDIS_URL=redis://localhost:6379/0

# ===========================
# Pipeline Backfill (kill switches)
# ===========================
# 段階的有効化: Step 1 で extractions、Step 2 で classifications、
# Step 3 で embeddings を順に true に切り替える。
BACKFILL_EXTRACTIONS_ENABLED=false
BACKFILL_CLASSIFICATIONS_ENABLED=false
BACKFILL_EMBEDDINGS_ENABLED=false

# ===========================
# App URLs
# ===========================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ===========================
# Frontend
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ===========================
# Frontend (Next.js BFF)
# ===========================
INTERNAL_API_URL=http://backend:8000/api/v1

# ===========================
# Docker Compose Port Mapping
# ===========================
DB_PORT=5433
REDIS_PORT=6379
